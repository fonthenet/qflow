# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web Push / VAPID (required for browser push notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Push webhook secret (optional — authenticates Supabase pg_net trigger calls to /api/push-send)
PUSH_WEBHOOK_SECRET=

# Apple Push Notification service (optional — for iOS App Clip push notifications)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8=
APNS_BUNDLE_ID=com.queueflow.app.QueueFlowClip

# App URL (optional — used for App Clip invocation URLs)
NEXT_PUBLIC_APP_URL=https://your-domain.com
