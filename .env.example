NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://qflo.net

# Optional SMS backup alerts (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Use either a messaging service SID or a sending phone number
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid
TWILIO_FROM_NUMBER=+15550000000

# Optional Android native live updates (FCM HTTP v1)
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Or provide the full service account JSON instead of the 3 vars above
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# Android app build-time Firebase client config
QUEUEFLOW_FIREBASE_PROJECT_ID=your-firebase-project-id
QUEUEFLOW_FIREBASE_APP_ID=1:1234567890:android:abcdef123456
QUEUEFLOW_FIREBASE_API_KEY=your-android-firebase-api-key
QUEUEFLOW_FIREBASE_SENDER_ID=1234567890

# WhatsApp (shared number for notifications)
WHATSAPP_SHARED_PHONE_NUMBER=+213xxxxxxxxx

# Messenger (Facebook Page integration)
MESSENGER_PAGE_ACCESS_TOKEN=your-page-access-token
MESSENGER_VERIFY_TOKEN=your-webhook-verify-token
MESSENGER_APP_SECRET=your-facebook-app-secret
