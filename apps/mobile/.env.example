# Qflo Mobile — Environment Variables
# Copy this file to .env.local (gitignored) and fill in real values.
#
# All variables must be prefixed with EXPO_PUBLIC_ so Metro includes them
# in the app bundle. They are safe to ship in a mobile bundle because they
# are already public (Supabase anon key is RLS-gated, not a secret key).

# Required: Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://ofyyzuocifigyyhqxxqw.supabase.co

# Required: Supabase anon key (public, RLS-gated)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: API base URL (defaults to https://qflo.net)
# EXPO_PUBLIC_API_URL=https://qflo.net
