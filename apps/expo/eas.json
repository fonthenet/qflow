{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "remote",
      "env": {
        "ELECTRON_SKIP_BINARY_DOWNLOAD": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "W69MRY2826",
        "ascAppId": "6761509429"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}
