{
  "expo": {
    "name": "Qflo",
    "slug": "queueflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "qflo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qflo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Qflo uses the camera to scan QR codes at service locations.",
        "NSUserNotificationsUsageDescription": "Qflo sends notifications to alert you when your turn is approaching so you can return to the desk in time.",
        "NSLocalNetworkUsageDescription": "Qflo scans your local Wi-Fi to discover a nearby Qflo Station for offline ticket join and check-in.",
        "NSLocationWhenInUseUsageDescription": "Qflo shares your location with the customer in real time so they can see your delivery progress.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Qflo keeps sharing your location with the customer while the app is in the background, so deliveries don't go silent when your phone locks.",
        "NSLocationAlwaysUsageDescription": "Qflo keeps sharing your location with the customer while the app is in the background.",
        "NSPhotoLibraryAddUsageDescription": "Qflo saves delivery proof photos to your library so you keep a record of completed orders.",
        "NSPhotoLibraryUsageDescription": "Qflo lets you pick a profile photo from your library.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification", "location", "fetch", "processing"]
      },
      "associatedDomains": [
        "applinks:qflo.net",
        "appclips:qflo.net"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d4ed8"
      },
      "package": "com.qflo.app",
      "usesCleartextTraffic": false,
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.WAKE_LOCK"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "qflo.net", "pathPrefix": "/q/" },
            { "scheme": "https", "host": "qflo.net", "pathPrefix": "/rider/" },
            { "scheme": "https", "host": "qflo.net", "pathPrefix": "/book/" },
            { "scheme": "https", "host": "qflo.net", "pathPrefix": "/kiosk/" }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Qflo needs camera access to scan QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1d4ed8",
          "defaultChannel": "queue-updates",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "privacyManifests": {
              "NSPrivacyAccessedAPITypes": [
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "CA92.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "C617.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "E174.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "35F9.1"
                  ]
                }
              ]
            }
          }
        }
      ],
      "expo-font",
      "./plugins/with-app-clip",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Qflo shares your location with the customer in real time during deliveries — even when the app is in the background or your phone is locked.",
          "locationAlwaysPermission": "Qflo keeps sharing your location with the customer while the app is in the background.",
          "locationWhenInUsePermission": "Qflo shares your location with the customer so they can see your delivery progress.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a1ab8ab-1344-43ec-bdd5-2f4b991f7b1f"
      }
    },
    "owner": "f.onthenet"
  }
}
