default_platform(:ios)

TEAM_ID = "W69MRY2826"
APP_IDENTIFIER = "com.queueflow.app"
CLIP_IDENTIFIER = "com.queueflow.app.QueueFlowClip"
PROJECT = "QueueFlow.xcodeproj"
SCHEME_APP = "QueueFlow"
SCHEME_CLIP = "QueueFlowClip"

platform :ios do

  # Helper: set up App Store Connect API key from env vars
  before_all do
    if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
      app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
        is_key_content_base64: false,
        in_house: false,
      )
    end
  end

  # Helper: set up CI keychain
  private_lane :setup_keychain do
    if is_ci
      # Delete stale keychain from previous runs if it exists
      sh("security delete-keychain ci_keychain 2>/dev/null || true")

      create_keychain(
        name: "ci_keychain",
        password: ENV["KEYCHAIN_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false,
      )

      # Ensure both CI keychain and system keychain are in search list
      sh("security list-keychains -d user -s ~/Library/Keychains/ci_keychain-db /Library/Keychains/System.keychain")
      sh("security unlock-keychain -p #{ENV['KEYCHAIN_PASSWORD']} ~/Library/Keychains/ci_keychain-db")
    end
  end

  # ─────────────────────────────────────────
  # Code Signing with Match
  # ─────────────────────────────────────────
  desc "Sync certificates and profiles via match (creates if missing)"
  lane :sync_certs do
    setup_keychain

    # App Store distribution certs & profiles for both targets
    # readonly: false so it creates certs if they don't exist yet
    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, CLIP_IDENTIFIER],
      readonly: false,
      git_url: ENV["MATCH_GIT_URL"],
      keychain_name: is_ci ? "ci_keychain" : "login.keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || "",
    )

    UI.success("✅ Certificates and profiles synced!")
  end

  # ─────────────────────────────────────────
  # Build for TestFlight
  # ─────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_keychain

    # Sync signing certs (readonly: false to ensure certs are imported to CI keychain)
    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, CLIP_IDENTIFIER],
      readonly: false,
      git_url: ENV["MATCH_GIT_URL"],
      keychain_name: is_ci ? "ci_keychain" : "login.keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || "",
    )

    # Increment build number (uses current timestamp for uniqueness)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: PROJECT,
    )

    # Update project signing settings to use match profiles
    update_code_signing_settings(
      use_automatic_signing: false,
      path: PROJECT,
      team_id: TEAM_ID,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore #{APP_IDENTIFIER}",
      targets: [SCHEME_APP],
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: PROJECT,
      team_id: TEAM_ID,
      bundle_identifier: CLIP_IDENTIFIER,
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore #{CLIP_IDENTIFIER}",
      targets: [SCHEME_CLIP],
    )

    # Build the archive
    build_app(
      project: PROJECT,
      scheme: SCHEME_APP,
      export_method: "app-store",
      destination: "generic/platform=iOS",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}",
          CLIP_IDENTIFIER => "match AppStore #{CLIP_IDENTIFIER}",
        },
      },
      output_directory: "./build",
      output_name: "QueueFlow.ipa",
      clean: true,
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_APPLE_ID"], # App's Apple ID from App Store Connect
      ipa: "./build/QueueFlow.ipa",
    )

    UI.success("✅ QueueFlow uploaded to TestFlight!")
  end

  # ─────────────────────────────────────────
  # Submit to App Store Review
  # ─────────────────────────────────────────
  desc "Submit the latest TestFlight build to App Store review"
  lane :release do
    deliver(
      submit_for_review: true,
      automatic_release: true,
      force: true, # Skip HTML report verification
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
      app_identifier: APP_IDENTIFIER,
      submission_information: {
        add_id_info_uses_idfa: false,
      },
    )
  end

  # ─────────────────────────────────────────
  # Build only (for CI validation)
  # ─────────────────────────────────────────
  desc "Build for simulator (no signing)"
  lane :build_debug do
    # Build App Clip
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME_CLIP,
      destination: "platform=iOS Simulator,name=iPhone 15,OS=latest",
      configuration: "Debug",
      build_settings: {
        "CODE_SIGN_IDENTITY" => "",
        "CODE_SIGNING_REQUIRED" => "NO",
        "CODE_SIGNING_ALLOWED" => "NO",
      },
    )

    # Build Companion App
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME_APP,
      destination: "platform=iOS Simulator,name=iPhone 15,OS=latest",
      configuration: "Debug",
      build_settings: {
        "CODE_SIGN_IDENTITY" => "",
        "CODE_SIGNING_REQUIRED" => "NO",
        "CODE_SIGNING_ALLOWED" => "NO",
      },
    )

    UI.success("✅ Both targets built successfully!")
  end

end
