{
  "name": "qflo-station",
  "version": "1.1.7",
  "description": "Qflo Operator Station — offline-first queue management",
  "main": "dist-electron/main.js",
  "author": "Qflo",
  "license": "PROPRIETARY",
  "scripts": {
    "dev": "vite",
    "dev:restart": "powershell -ExecutionPolicy Bypass -File build/dev-restart.ps1",
    "build": "tsc && vite build && electron-builder --win --x64",
    "build:dir": "tsc && vite build && electron-builder --win --dir",
    "build:installer": "tsc && vite build && electron-builder --win nsis",
    "build:ia32": "tsc && vite build && electron-builder --win nsis --ia32",
    "build:all-arch": "tsc && vite build && electron-builder --win nsis --x64 --ia32",
    "build:vite": "tsc && vite build",
    "sync-web": "bash sync-web-station.sh",
    "build:all": "tsc && vite build && bash sync-web-station.sh && electron-builder --win",
    "start": "electron dist-electron/main.js",
    "preview": "vite preview",
    "test": "vitest run",
    "posttest": "cd ../../node_modules/.pnpm/better-sqlite3@11.10.0/node_modules/better-sqlite3 && npx --yes prebuild-install --runtime=electron --target=35.7.5 --arch=x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.3.9",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.qflo.station",
    "productName": "Qflo Station",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "win": {
      "artifactName": "Qflo-Station-Setup-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "shortcutName": "Qflo Station",
      "buildUniversalInstaller": false
    },
    "publish": {
      "provider": "github",
      "owner": "fonthenet",
      "repo": "qflow"
    }
  }
}
